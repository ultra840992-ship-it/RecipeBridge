/* filepath: dashboard-ui/src/index.css */
/* 기본 스타일 초기화 */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

:root {
  font-family: 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
  line-height: 1.5;
  font-weight: 400;

  color-scheme: light dark;
  color: rgba(255, 255, 255, 0.87);
  background-color: #242424;

  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  margin: 0;
  display: flex;
  place-items: center;
  min-width: 320px;
  min-height: 100vh;
  background-color: #1a1a1a;
  color: #e0e0e0;
}

#root {
  max-width: 1280px;
  margin: 0 auto;
  padding: 2rem;
  text-align: center;
  width: 100%;
}

/* App.jsx용 스타일 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20px;
  padding: 40px;
  border-radius: 12px;
  background-color: #2c2c2c;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
}

.title {
  font-size: 2.5em;
  font-weight: 700;
  color: #61dafb; /* React blue */
  margin-bottom: 10px;
}

.description {
  font-size: 1.1em;
  color: #b0b0b0;
  margin-bottom: 20px;
  max-width: 600px;
}

.button-group {
  display: flex;
  gap: 15px;
  margin-top: 20px;
}

.button {
  padding: 15px 30px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-size: 1.1em;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);
}

.button.primary {
  background-color: #61dafb; /* React blue */
  color: #202020;
}

.button.primary:hover {
  background-color: #21a1f1;
  transform: translateY(-2px);
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
}

.button.secondary {
  background-color: #e0e0e0;
  color: #202020;
}

.button.secondary:hover {
  background-color: #c0c0c0;
  transform: translateY(-2px);
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
}

.footer {
  margin-top: 40px;
  font-size: 0.85em;
  color: #707070;
}
